    -- ============================================
    -- КУБ
    -- ============================================
    Cube = {
        BaseHealth = 200,            -- Прочность куба
        DamageReduction = 0.5,       -- 50% урона в кубе
    },
    
    -- ============================================
    -- АГРЕССИЯ
    -- ============================================
